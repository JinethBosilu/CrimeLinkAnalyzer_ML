# Database Configuration
DB_HOST=autorack.proxy.rlwy.net
DB_PORT=13200
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your_password_here

# Or use connection URL directly
DATABASE_URL=postgresql://postgres:your_password@autorack.proxy.rlwy.net:13200/railway

# Server Configuration
PORT=5002
HOST=0.0.0.0

# Storage Configuration
UPLOAD_DIR=uploads
SUSPECT_IMAGES_DIR=suspect_images
MODEL_DIR=model
MAX_FILE_SIZE_MB=5

# Recognition Settings
DEFAULT_THRESHOLD=75
MIN_FACE_SIZE=80
DETECTION_SIZE=640

# Logging
LOG_LEVEL=INFO
LOG_FILE=facial_recognition.log

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
